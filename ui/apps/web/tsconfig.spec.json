{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "out-tsc/spec",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["dom"],
    "tsBuildInfoFile": "out-tsc/spec/tsconfig.spec.tsbuildinfo",
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*.spec.ts", "src/**/*.spec.tsx"],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
