{
  "description": "The canonical straight line with the operator fields unset: a perfectly shaped graph that cannot compile until an operator picks the Engine and Execution Model.",
  "rules": ["missing-operator-fields"],
  "config": {
    "nodes": [
      { "id": "positions-source", "type": "source", "sourceId": "positions" },
      {
        "id": "client-filter",
        "type": "transform",
        "kind": "clientFilter",
        "clientIds": ["INV-001", "INV-002", "INV-003"]
      },
      { "id": "pomeroy-delivery", "type": "destination", "destinationId": "pomeroy-provider" }
    ],
    "edges": [
      { "from": "positions-source", "to": "client-filter" },
      { "from": "client-filter", "to": "pomeroy-delivery" }
    ],
    "schedule": null,
    "engine": null,
    "executionModel": null
  }
}
