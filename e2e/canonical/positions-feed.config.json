{
  "nodes": [
    {
      "id": "positions-source",
      "type": "source",
      "sourceId": "positions"
    },
    {
      "id": "client-filter",
      "type": "transform",
      "kind": "clientFilter",
      "clientIds": ["INV-001", "INV-002", "INV-003"]
    },
    {
      "id": "pomeroy-delivery",
