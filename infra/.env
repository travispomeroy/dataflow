# Mock-world credentials — deliberately committed; nothing here is real.
# Single source of truth for compose interpolation (docker-compose.yml) and the
# gate (e2e/m0-gates.sh: node --env-file=infra/.env for the smoke checks, and a
# direct grep of SFTP_PASSWORD for the sftp login stage).
POSTGRES_SUPERUSER_PASSWORD=postgres-superuser-local
KESTRA_DB_PASSWORD=kestra-db-local
DATAFLOW_DB_PASSWORD=dataflow-db-local
KESTRA_UI_USER=admin@dataflow.local
# Kestra validates credential complexity (uppercase + digit + special char);
# weak values are silently ignored and Kestra falls back to its setup page
KESTRA_UI_PASSWORD=KestraAdmin1234!
MINIO_ROOT_USER=dataflow-minio
MINIO_ROOT_PASSWORD=minio-root-local
SFTP_PASSWORD=pomeroy-sftp-local
NIFI_USER=nifi-admin
# NiFi silently discards a single-user password shorter than 12 characters and
# generates random credentials instead (docs/versions.md) — keep this >= 12
NIFI_PASSWORD=nifi-admin-local
# Kestra OSS secrets are SECRET_<name> env vars with base64-encoded values; compose
# cannot encode, so the encodings are committed alongside the plain values they
# derive from (MINIO_ROOT_USER, MINIO_ROOT_PASSWORD, SFTP_PASSWORD, NIFI_USER,
# NIFI_PASSWORD above).
# Regenerate with `printf %s '<value>' | base64` whenever a plain value changes.
KESTRA_SECRET_MINIO_ACCESS_KEY_B64=ZGF0YWZsb3ctbWluaW8=
KESTRA_SECRET_MINIO_SECRET_KEY_B64=bWluaW8tcm9vdC1sb2NhbA==
KESTRA_SECRET_SFTP_POMEROY_B64=cG9tZXJveS1zZnRwLWxvY2Fs
KESTRA_SECRET_NIFI_USERNAME_B64=bmlmaS1hZG1pbg==
KESTRA_SECRET_NIFI_PASSWORD_B64=bmlmaS1hZG1pbi1sb2NhbA==
